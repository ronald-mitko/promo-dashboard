# Copy to .env.local and fill in. .env.local is git-ignored — never commit secrets.
# Locally, run the app + API together with:  npx vercel dev   (binds 127.0.0.1)

# ── Fabric SQL: reference data (teams/clients/chains/stores/items) ──
# Same service principal + server the workflag-submission app uses.
AAD_TENANT_ID=
AAD_CLIENT_ID=
AAD_CLIENT_SECRET=
FABRIC_SQL_SERVER=
FABRIC_SQL_DATABASE=

# ── Vercel Postgres: stores submissions (priorities + requests) ──
# Auto-added to the Vercel project when you create a Postgres store.
# For local dev, paste the connection string here.
POSTGRES_URL=

# ── Frontend flag ──
# 1 = use the API (live DB). Unset/0 = seed data + localStorage (offline dev, default).
VITE_API=1
